# libsql 연결 문자열
# 로컬 개발: 파일 기반 SQLite
DATABASE_URL=file:./local.db
# Turso 배포 시:
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-token-here

# Better Auth — 쿠키 서명/암호화 키. `npx @better-auth/cli@latest secret` 또는
# `openssl rand -base64 32`로 생성. dev/prod 분리 권장.
BETTER_AUTH_SECRET=
# 배포 시 자기 도메인. 콜백 URL 생성 등에 사용.
BETTER_AUTH_URL=http://localhost:3000
# 클라이언트 측 baseURL — Better Auth client가 어느 origin으로 fetch할지.
# NEXT_PUBLIC_ prefix라 클라이언트 번들에 포함. 미설정 시 prod에서 localhost로
# fetch → CORS 차단되니 환경별 명시 필수.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth App credentials
# https://github.com/settings/developers → New OAuth App
# Authorization callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=