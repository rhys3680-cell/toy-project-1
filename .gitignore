# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# project docs (local-only planning notes)
/docs

# scratch playground (local-only ORM experiments)
/scratch

# blog drafts (local-only writeups)
/blog

# playground (local-only Deno + Jupyter experiments)
/playground

# local sqlite database (gen by drizzle-kit migrate)
/local.db
/local.db-journal
/local.db-shm
/local.db-wal
